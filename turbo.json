{
	"$schema": "https://turborepo.dev/schema.json",
	"globalEnv": ["AWS_PROFILE", "AWS_REGION", "AWS_APP_ID", "AWS_BRANCH"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**", "amplify_outputs.json"]
		},
		"lint": {},
		"check-types": {},
		"dev": {
			"cache": false,
			"persistent": true
		}
	},
	"ui": "tui"
}
