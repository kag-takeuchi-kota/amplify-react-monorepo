{
	"extends": "@repo/typescript-config/frontend.json",
	"include": ["src"],
	"compilerOptions": {
		"tsBuildInfoFile": "node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"incremental": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"declarationMap": true,
		"outDir": "dist",
		"rootDir": "src",
		"paths": {
			"@/*": ["./src/*"]
		}
	}
}
